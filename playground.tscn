[sub_resource type="GDScript" id="GDScript_ynsuh"]
script/source = "extends Node2D
const AUDIO = preload(\"res://general/audio/ability_acquire.wav\")
var player : Player = null
var pool : bool = true



func _ready() -> void:
	set_player_abilities()
	#play_sound()
	pass # Replace with function body.



func _unhandled_input(event: InputEvent) -> void:
	# DEBUG
	if OS.is_debug_build():
		if event is InputEventKey and event.pressed:
			if event.keycode == KEY_P:
				pool = !pool
				print(\"pool = \", pool)
	pass



func set_player_abilities() -> void:
	while not player:
		await get_tree().create_timer(0.05).timeout
		player = get_tree().get_first_node_in_group(\"Player\")
	player.dash = true
	player.double_jump = true
	player.ground_slam = true
	player.morph_roll = true
	pass



func play_sound() -> void:
	await get_tree().create_timer( 0.01 ).timeout
	if player:
		#Audio.play_spatial_sound( AUDIO, player.global_position )
		Audio.play_spatial_sound( AUDIO, player.global_position, !pool )
		pass
	play_sound()
	pass
"

